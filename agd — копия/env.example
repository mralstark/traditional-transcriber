# Скопируй в .env и заполни. .env НЕ коммитить (он в .gitignore).

# HuggingFace token — нужен для pyannote (модели gated).
# 1) huggingface.co → Settings → Access Tokens → создать read-токен
# 2) прими условия на страницах:
#    huggingface.co/pyannote/speaker-diarization-3.1
#    huggingface.co/pyannote/embedding
HF_TOKEN=

# Anthropic API key — нужен только для scripts/edit_pass.py (стадия B пакетно).
# Если редактируешь прямо в сессии Claude Code — этот ключ не обязателен.
ANTHROPIC_API_KEY=

# --- опционально: облачный ASR вместо локального (данные уходят провайдеру) ---
